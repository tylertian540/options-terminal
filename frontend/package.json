{
  "name": "options-terminal-frontend",
  "version": "1.0.0",
  "description": "Goldman Sachs-Level Options Analysis Terminal Frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":          "vite --port 3000",
    "build":        "tsc && vite build",
    "preview":      "vite preview",
    "test":         "vitest run",
    "test:watch":   "vitest",
    "type-check":   "tsc --noEmit",
    "lint":         "eslint src --ext .ts,.tsx",
    "lint:fix":     "eslint src --ext .ts,.tsx --fix"
  },
  "dependencies": {
    "react":                    "^18.3.0",
    "react-dom":                "^18.3.0",
    "d3":                       "^7.9.0",
    "three":                    "^0.168.0",
    "zustand":                  "^4.5.0",
    "react-query":              "^5.0.0",
    "@tanstack/react-query":    "^5.56.0",
    "react-resizable-panels":   "^2.0.0",
    "framer-motion":            "^11.0.0",
    "date-fns":                 "^3.6.0",
    "lodash-es":                "^4.17.21",
    "axios":                    "^1.7.0",
    "socket.io-client":         "^4.7.0",
    "recharts":                 "^2.12.0",
    "react-virtualized-auto-sizer": "^1.0.24",
    "react-window":             "^1.8.10"
  },
  "devDependencies": {
    "@types/react":             "^18.3.0",
    "@types/react-dom":         "^18.3.0",
    "@types/d3":                "^7.4.3",
    "@types/three":             "^0.168.0",
    "@types/lodash-es":         "^4.17.12",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser":        "^7.0.0",
    "@vitejs/plugin-react":     "^4.3.0",
    "eslint":                   "^8.57.0",
    "typescript":               "^5.5.0",
    "vite":                     "^5.4.0",
    "vitest":                   "^2.0.0",
    "@testing-library/react":   "^16.0.0",
    "@testing-library/jest-dom":"^6.0.0",
    "jsdom":                    "^25.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm":  ">=10.0.0"
  }
}
