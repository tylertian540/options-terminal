# ============================================================
# Options Terminal — 环境变量配置模板
# 复制为 .env 并填入实际值
# ============================================================

# ─── 数据库 ───
DB_USER=options
DB_PASSWORD=your_secure_password_here
DB_NAME=options_terminal

# ─── 数据源 API Keys ───
# Polygon.io (推荐): https://polygon.io/dashboard  ← 注册获取
# 免费版: 15秒延迟  |  Starter $29/月: 实时数据
POLYGON_API_KEY=your_polygon_api_key_here

# Tradier (备用): https://developer.tradier.com
TRADIER_API_KEY=your_tradier_api_key_here

# ─── 服务配置 ───
REDIS_URL=redis://redis:6379
SECRET_KEY=generate-a-random-64-char-string-here
ENVIRONMENT=development    # development | production

# ─── 前端URL（生产环境修改为域名）───
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# ─── 日志 ───
LOG_LEVEL=INFO    # DEBUG | INFO | WARNING | ERROR

# ─── 监控（可选）───
GRAFANA_PASSWORD=admin

# ─── 生产环境额外配置 ───
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem
# ALLOWED_ORIGINS=https://your-domain.com
